# ---- Slack tokens -----------------------------------------------------------
# Bot token (xoxb-...): used to receive events and post threaded incoming
# translations / ephemeral notes.
SLACK_BOT_TOKEN=xoxb-your-bot-token

# USER token (xoxp-...): used to act AS YOU — delete your own messages and
# re-post translated versions in your place. This is the token that makes
# outgoing translation appear as you.
SLACK_USER_TOKEN=xoxp-your-user-token

# App-level token (xapp-...) with connections:write — required for Socket Mode.
SLACK_APP_TOKEN=xapp-your-app-token

# ---- Translation engine -----------------------------------------------------
# "claude" = context-aware, paid (~$2-3 per 1,000 messages).
# "google" = free, no API key, but translates each message without conversation
#            context (lower nuance). Uses deep-translator + langdetect.
TRANSLATION_ENGINE=google

# ---- Anthropic (only needed when TRANSLATION_ENGINE=claude) ------------------
ANTHROPIC_API_KEY=sk-ant-your-key

# Model used for translation. Default is claude-sonnet-4-6 (good speed/cost for
# high message volume). Use claude-opus-4-8 for maximum quality.
ANTHROPIC_MODEL=claude-sonnet-4-6

# ---- Behavior (all optional) ------------------------------------------------
# Fallback language I read incoming messages in, when a conversation has no
# per-conversation reading language set.
DEFAULT_READING_LANG=en

# Fallback outgoing target when auto-detection can't determine the recipients'
# language and no forced target is set.
DEFAULT_TARGET_LANG=en

# SQLite file for per-conversation settings.
DB_PATH=translator.db

# How many recent messages to pass to Claude as translation context.
CONTEXT_MESSAGES=8

# Prefix that bypasses translation for a single outgoing message.
RAW_PREFIX=!raw

# Post incoming translations as an ephemeral note (only you see it) instead of a
# threaded reply visible to the channel. true/false.
INCOMING_EPHEMERAL=false

# Mode:
#   replace  — delete YOUR OWN messages and re-post them translated (single operator).
#   annotate — never delete anything; post a PRIVATE translation of EVERY message
#              (from anyone) to the viewer group. One bot handles everyone.
TRANSLATION_MODE=annotate

# Teammates who should ALSO privately see incoming translations (besides you).
# Comma-separated Slack user IDs (e.g. U0123ABCD) and/or @handles / display names.
# Each must be a member of the channel. Leave empty for "just me".
# In a multi-bot setup, set this the SAME in every instance so they agree.
# Example: TRANSLATION_VIEWERS=U0123ABCD, john.doe
TRANSLATION_VIEWERS=

# Better for multi-bot: an ABSOLUTE path to a shared viewer-list file that EVERY
# instance reads, so the list is identical everywhere and edited in one place.
# One entry per line (IDs or @handles/names), '#' for comments. Re-read on change
# (no restart). Leave empty to use TRANSLATION_VIEWERS instead.
# Example: VIEWERS_FILE=/Users/you/slack-translator/viewers.txt
VIEWERS_FILE=

# ---- Multi-bot (one bot per person) -----------------------------------------
# Only needed if more than one person runs their own bot in the same workspace.
# Each person needs their OWN separate Slack app (separate bot/app/user tokens).
#
# PEER_BOT_USERS: the OTHER people who run their own bot. This instance won't
# translate their messages as "incoming" (their bot handles their own messages).
# Example (in Joyce's .env): PEER_BOT_USERS=phuong
PEER_BOT_USERS=
#
# IS_PRIMARY: exactly ONE instance should be true. The primary also translates
# messages from people who have no bot at all (e.g. an English-only colleague).
# Set false on every non-primary instance.
IS_PRIMARY=true

# Logging level: DEBUG / INFO / WARNING
LOG_LEVEL=INFO
